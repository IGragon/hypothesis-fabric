# Yandex AI Studio
YC_FOLDER_ID=
YC_API_KEY=

# RouterAI.ru
ROUTERAI_API_KEY=

# ProxyAPI
PROXY_API_KEY=

# DeepSeek API
DEEPSEEK_API_KEY=

# ---

# Select LLM provider for BOTH CLI and API runs (deepseek|yandex|routerai|proxyapi|local).
# When unset, defaults to deepseek. Set to yandex if you have YC creds above.
HFABRIC_PROVIDER=

# Vision model for image parsing (optional; needed for VLM image descriptions)
# Leave blank to disable VLM and use OCR-only for images.
HFABRIC_VISION_PROVIDER=
HFABRIC_VISION_MODEL=

MEMGRAPH_URI=bolt://localhost:7687

# HuggingFace token — avoids rate limits on embedding model download.
HF_TOKEN=

# --- External grounding sources (optional but recommended) ---
# Which sources to query: comma-separated subset of web,mp,citrination,nims
# or one of the legacy presets: web | web+mp | all | none. Default: web
HFABRIC_EXTERNAL_SEARCH=web

# Material Project — synthesis + materials search. Free key.
# Get one at https://next-gen.materialsproject.org/dashboard
MP_API_KEY=

# Citrination — material data PIF search. Optional.
# Get one at https://citrination.com
CITRINATION_API_KEY=
CITRINATION_BASE_URL=https://citrination.com

# NIMS MatNavi — Japanese materials database (HTML scraping, experimental).
NIMS_MATNAVI_BASE_URL=https://mits.nims.go.jp

# --- Logging ---
# Pipeline log verbosity: INFO (default) or DEBUG (per-hypothesis feature vectors).
HFABRIC_LOG_LEVEL=INFO

# --- Web search tuning (advanced) ---
# DuckDuckGo region code (ru-ru works best for Russian metallurgy queries).
HFABRIC_WEB_REGION=ru-ru
# Number of retry attempts when ddgs returns 0 hits or errors.
HFABRIC_WEB_RETRIES=3